--  List all customers who have made more than 10 purchases.
SELECT CustomerID,
       COUNT(*) AS Total_Purchases
FROM SALES1
GROUP BY CustomerID
HAVING COUNT(*) > 10;

-- List all pairs of customers who 
-- have made purchases with the same salesperson.

SELECT DISTINCT
       S1.CustomerID AS Customer1,
       S2.CustomerID AS Customer2,
       S1.SalesPersonID
FROM SALES1 S1
JOIN SALES1 S2
ON S1.SalesPersonID = S2.SalesPersonID
AND S1.CustomerID < S2.CustomerID;
































