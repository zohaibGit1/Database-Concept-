select * from dataset1.smartphones;

# Question 1
select round(avg(battery_capacity)) as Battery_Capacity,
	   round(avg(primary_camera_rear)) as Primary_Rear_Camera
       from dataset1.smartphones
       where price >= 100000;
	
# Question 2
select avg(internal_memory) as RAM
	   from dataset1.smartphones
	   where refresh_rate >= 120 AND 
			 primary_camera_front >= 20;
             
             
# Question 3

select count(1)
	  from dataset1.smartphones 
      where has_5g = 'true';
